{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{ range .Pages }}
    {{ $seo := .Params.seo | default dict }}
    {{ if and (not .Sitemap.Disable) (not (index $seo "noindex")) }}
      <url>
        <loc>{{ .Permalink }}</loc>
        {{ if not .Lastmod.IsZero }}
          <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
        {{ end }}
        {{ with .Sitemap.ChangeFreq }}
          <changefreq>{{ . }}</changefreq>
        {{ end }}
        {{ if ge .Sitemap.Priority 0.0 }}
          <priority>{{ .Sitemap.Priority }}</priority>
        {{ end }}
      </url>
    {{ end }}
  {{ end }}

  {{ range (slice "/pages" "/posts") }}
    {{ with site.GetPage . }}
      {{ $sectionPage := . }}
      {{ $paginator := $sectionPage.Paginate ($sectionPage.RegularPages.ByDate.Reverse) }}
      {{ if gt $paginator.TotalPages 1 }}
        {{ range $paginator.Pagers }}
          {{ if gt .PageNumber 1 }}
            <url>
              <loc>{{ .URL | absLangURL }}</loc>
              {{ if not $sectionPage.Lastmod.IsZero }}
                <lastmod>{{ $sectionPage.Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
              {{ end }}
              {{ with $sectionPage.Sitemap.ChangeFreq }}
                <changefreq>{{ . }}</changefreq>
              {{ end }}
              {{ if ge $sectionPage.Sitemap.Priority 0.0 }}
                <priority>{{ $sectionPage.Sitemap.Priority }}</priority>
              {{ end }}
            </url>
          {{ end }}
        {{ end }}
      {{ end }}
    {{ end }}
  {{ end }}
</urlset>