{
  "name": "rhino-inquisitor-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "phase1:parse-sitemap": "node scripts/parse-sitemap.js",
    "phase1:crawl-urls": "node scripts/crawl-urls.js",
    "phase1:enrich-search-console": "node scripts/enrich-search-console.js",
    "phase1:classify-urls": "node scripts/classify-urls.js",
    "phase1:seo-baseline": "node scripts/seo-baseline.js",
    "phase1:perf-baseline": "node scripts/perf-baseline.js",
    "migrate:extract": "node scripts/migration/extract.js",
    "migrate:normalize": "node scripts/migration/normalize.js",
    "migrate:convert": "node scripts/migration/convert.js",
    "migrate:map-frontmatter": "node scripts/migration/map-frontmatter.js",
    "migrate:download-media": "node scripts/migration/download-media.js",
    "migrate:rewrite-media": "node scripts/migration/rewrite-media-refs.js",
    "migrate:rewrite-links": "node scripts/migration/rewrite-links.js",
    "migrate:apply-corrections": "node scripts/migration/run-correction-pipeline.js",
    "migrate:finalize-content": "npm run migrate:rewrite-media && npm run migrate:rewrite-links && npm run migrate:apply-corrections",
    "migrate:report": "node scripts/migration/generate-report.js",
    "migrate:pilot-candidates": "node scripts/migration/generate-pilot-candidates.js",
    "migrate:export-alt-corrections": "node scripts/migration/export-alt-text-corrections.js",
    "migrate:export-link-text-corrections": "node scripts/migration/export-link-text-corrections.js",
    "build:prod": "hugo --minify --environment production",
    "test:url-parity": "node --test scripts/migration/validate-url-parity.test.js",
    "validate:frontmatter": "node scripts/validate-frontmatter.js",
    "check:url-parity": "node scripts/migration/validate-url-parity.js",
    "check:url-parity:baseline": "node scripts/check-url-parity.js",
    "check:redirects": "node scripts/migration/check-redirects.js",
    "check:redirects:seo": "node scripts/seo/check-redirects.js",
    "check:crawl-controls": "node scripts/seo/check-crawl-controls.js",
    "check:metadata": "node scripts/seo/check-metadata.js",
    "check:images": "node scripts/seo/check-images.js",
    "check:non-html-policy": "node scripts/seo/build-non-html-policy.js",
    "check:schema": "node scripts/seo/check-schema.js",
    "check:sitemap": "node scripts/seo/check-sitemap.js",
    "check:media": "node scripts/migration/check-media.js",
    "check:seo": "npm run build:prod && node scripts/check-seo.js",
    "check:seo:artifact": "node scripts/check-seo.js",
    "check:noindex": "node scripts/check-noindex.js",
    "check:seo-completeness": "node scripts/migration/check-seo-completeness.js",
    "check:feed-compatibility": "node scripts/migration/check-feed-compatibility.js",
    "check:internal-links": "node scripts/seo/check-internal-links.js",
    "check:links": "node scripts/check-links.js",
    "check:pages-constraints": "node scripts/seo/check-pages-constraints.js",
    "check:security-content": "hugo --cleanDestinationDir --minify --environment production --contentDir migration/output/content --destination tmp/rhi041-public && node scripts/migration/check-security-content.js --public-dir tmp/rhi041-public",
    "check:migration-thresholds": "node scripts/migration/check-migration-thresholds.js",
    "check:security": "npm run build:prod && node scripts/check-security.js",
    "check:a11y-content": "node scripts/migration/check-a11y-content.js",
    "check:a11y": "npm run build:prod && node scripts/check-a11y.js",
    "check:a11y:seo": "node scripts/seo/check-a11y.js",
    "check:perf:budget": "node scripts/check-perf-budget.js",
    "check:perf:gate": "rm -rf tmp/lhci && npm run check:perf:budget && lhci autorun --config=./lighthouserc.json && node scripts/check-perf-report.js",
    "check:perf": "npm run build:prod && npm run check:perf:gate"
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "cheerio": "^1.2.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "6.6.0",
    "fast-glob": "3.3.3",
    "fast-xml-parser": "5.4.2",
    "file-type": "^21.3.1",
    "gray-matter": "4.0.3",
    "image-size": "^2.0.2",
    "p-limit": "7.3.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.2",
    "undici": "7.22.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "lighthouse": "13.0.3",
    "markdownlint-cli2": "0.17.2",
    "pa11y-ci": "3.1.0",
    "playwright": "1.58.2"
  }
}
