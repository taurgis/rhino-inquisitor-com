{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "url": [
        "http://localhost/",
        "http://localhost/phase-3-performance-baseline/",
        "http://localhost/category/platform/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 200
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./tmp/lhci"
    }
  }
}