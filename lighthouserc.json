{
  "ci": {
    "collect": {
      "staticDistDir": "./public",
      "url": [
        "http://localhost/",
        "http://localhost/sending-emails-from-sfcc/",
        "http://localhost/category/technical/"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "first-contentful-paint": [
          "error",
          {
            "maxNumericValue": 3000,
            "aggregationMethod": "median"
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 4000,
            "aggregationMethod": "median"
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1,
            "aggregationMethod": "median"
          }
        ],
        "interactive": [
          "error",
          {
            "maxNumericValue": 5000,
            "aggregationMethod": "median"
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.75,
            "aggregationMethod": "median"
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.8,
            "aggregationMethod": "median"
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./tmp/lhci"
    }
  }
}