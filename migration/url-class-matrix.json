      },
      "notes": "If strict request-time lowercase redirecting is required for all legacy variants, assign edge-cdn in Phase 2 routing decisions."
    },
    "query_parameters": {
      "decision": "Tracking query parameters are excluded from canonical URLs. Crawlable filter states must either canonicalize to a stable URL or be explicitly controlled by indexability policy.",
