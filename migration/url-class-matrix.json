          "patterns": [
            "s"
          ],
          "indexability": "noindex-or-exclude",
          "canonical_behavior": "none-required"
        },
        {
          "class": "pagination_query",
          "patterns": [
            "page"
          ],
          "indexability": "policy-controlled",
          "canonical_behavior": "must map to approved canonical route"
        },
        {
          "class": "unknown",
          "patterns": [
            "*"
          ],
          "indexability": "review-required",
          "canonical_behavior": "default to stable canonical URL"
