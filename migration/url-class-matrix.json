        }
      },
      "notes": "No-slash to slash HTTP redirects are not guaranteed by static hosting alone; this policy requires canonical alignment now and redirect hardening in later phases if needed."
    },
    "case": {
      "decision": "All generated and internal URLs must be lowercase. Legacy mixed-case requests should canonicalize to lowercase and can be redirected at edge when required.",
